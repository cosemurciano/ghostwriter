{
    "name": "cosemurciano/ghostwriter",
    "description": "Produzione di libri completi (PDF + ePub) in WordPress con AI in background.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "mpdf/mpdf": "^8.3",
        "opis/json-schema": "^2.6",
        "woocommerce/action-scheduler": "^3.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "brain/monkey": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "Ghostwriter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ghostwriter\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": false
    },
    "scripts": {
        "test": "phpunit"
    }
}
